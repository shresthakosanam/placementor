{
  "version": 2,
  "builds": [
    {
      "src": "api.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/results",
      "dest": "/results.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
